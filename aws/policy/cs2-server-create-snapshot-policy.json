{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "VisualEditor0",
			"Effect": "Allow",
			"Action": [
				"ec2:CreateTags",
				"ec2:CreateSnapshot"
			],
			"Resource": [
				"arn:aws:ec2:${str_aws_region}:${str_aws_account_id}:volume/*",
				"arn:aws:ec2:${str_aws_region}::snapshot/*"
			]
		}
	]
}